@startuml
title Resume Parser Service - Activity Diagram For Experience Parsing

start

:Receive blocks from experience section;
:Merge blocks into experience section text;
:Split section into candidate job entries;

repeat
  :Take next candidate entry;
  :Extract text of current candidate entry;
  :Split entry into lines;
  :Detect header lines\nand descriptive lines;

  :Search date range in header\nor entry text;

  if (Date range found?) then (yes)
    :Save start date,\nend date and original date range;
  else (no)
    :Continue without date fields;
  endif

  :Analyze header lines and detect\ncompany, job title and location;

  :Separate bullet points from\nplain description text;

  if (Bullet points found?) then (yes)
    :Save bullet points;
  else (no)
    :Continue without bullet points;
  endif

  if (Description text remains?) then (yes)
    :Save remaining text as description;
  else (no)
    :Continue without description text;
  endif

  :Create structured experience record;
  :Add record to parsed experience list;

repeat while (More candidate entries?) is (yes)

if (Reliable experience records found?) then (yes)
  :Return parsed experience records;
else (no)
  :Save original experience text\nfor fallback processing;
endif

stop
@enduml
