@startuml
title Схема зберігання результату парсингу резюме

hide methods
hide stereotypes
skinparam shadowing false

entity "Розпарсений документ" as ParsedDocument {
  * Ідентифікатор
  --
  Власник джерела
  Збережений структурований вміст
  Метадані створення
  Метадані оновлення
}

entity "Структурований вміст резюме" as StructuredResumeContent {
  Контактна інформація
  Загальний опис
  Записи про досвід
  Записи про освіту
  Групи навичок
  Сертифікати
  Записи про мови
  Записи про проєкти
  Технічні метадані
  Нерозподілені фрагменти вмісту
}

entity "Технічні метадані" as TechnicalMetadata {
  Стан парсингу
  Попередження валідації
  Характеристики витягання
  Характеристики макета
  Ознаки fallback-обробки
}

entity "Контактна інформація" as ContactInformation {
  Ідентифікаційні дані
  Канали зв'язку
  Посилання на публічні профілі
}

entity "Запис про досвід" as ExperienceRecord {
  Відомості про роботодавця
  Опис ролі
  Інтервал дат
  Місце роботи
  Пункти досягнень
}

entity "Запис про освіту" as EducationRecord {
  Відомості про заклад
  Дані про кваліфікацію
  Інтервал дат
  Локація
  Додаткова примітка
}

entity "Група навичок" as SkillGroup {
  Назва категорії
  Елементи навичок
}

entity "Запис про сертифікат" as CertificateRecord {
  Назва сертифіката
  Організація-видавець
  Дата отримання
}

entity "Запис про мову" as LanguageRecord {
  Назва мови
  Рівень володіння
}

entity "Запис про проєкт" as ProjectRecord {
  Назва проєкту
  Короткий опис
  Довідкове посилання
}

ParsedDocument ||--|| StructuredResumeContent : зберігає
StructuredResumeContent ||--|| TechnicalMetadata
StructuredResumeContent ||--|| ContactInformation
StructuredResumeContent ||--o{ ExperienceRecord
StructuredResumeContent ||--o{ EducationRecord
StructuredResumeContent ||--o{ SkillGroup
StructuredResumeContent ||--o{ CertificateRecord
StructuredResumeContent ||--o{ LanguageRecord
StructuredResumeContent ||--o{ ProjectRecord

@enduml
